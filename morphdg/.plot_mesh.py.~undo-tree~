def _plot_mesh(mesh_obj):
    \"\"\"Natively plots the C++ morphdG mesh using Matplotlib.\"\"\"
    fig, ax = plt.subplots(figsize=(8, 8))
    
    # Grab the C++ memory
    nodes = mesh_obj.nodes.reshape(-1, 2)         
    triangles = mesh_obj.triangles.reshape(-1, 3) 
    faces = mesh_obj.faces.reshape(-1, 4)         
    bnd_faces = mesh_obj.bnd_faces.reshape(-1, 4) 
    
    # Draw Fine Triangles
    patches = [Polygon(nodes[tri], closed=True) for tri in triangles]
    p = PatchCollection(patches, facecolor='none', edgecolors='gray', linewidths=0.5, zorder=1)
    ax.add_collection(p)
    
    # Draw Internal Faces
    for f in faces:
        nA, nB = f[2], f[3]
        ax.plot([nodes[nA, 0], nodes[nB, 0]], [nodes[nA, 1], nodes[nB, 1]], color='black', linewidth=2.5, zorder=3)
        
    # Draw Boundary Faces
    for f in bnd_faces:
        nA, nB = f[2], f[3]
        ax.plot([nodes[nA, 0], nodes[nB, 0]], [nodes[nA, 1], nodes[nB, 1]], color='black', linewidth=2.5, zorder=3)

    # Draw Labels
    for p_idx in range(mesh_obj.num_elements):
        start = mesh_obj.t_offsets[p_idx]
        end = mesh_obj.t_offsets[p_idx + 1]
        poly_nodes = nodes[triangles[start:end]]
        cx, cy = np.mean(poly_nodes[:, :, 0]), np.mean(poly_nodes[:, :, 1])
        ax.text(cx, cy, str(p_idx), color='darkred', fontsize=14, ha='center', va='center', weight='bold', zorder=5)

    ax.autoscale_view()
    ax.set_aspect('equal')
    plt.axis('off')
    plt.title(f'morphdG Mesh: {mesh_obj.num_elements} Elements')
