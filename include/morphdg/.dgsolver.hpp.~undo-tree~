                     mesh.h_nodes[2 * n3], mesh.h_nodes[2 * n3 + 1], B00, B01, B10, B11, cx, cy);

      for (int q = 0; q < n_q; ++q) {
        double s, t_coord, w;
        QuadData::get_vol(q, s, t_coord, w);

        x_quads[t * n_q + q] = B00 * s + B01 * t_coord + cx;
